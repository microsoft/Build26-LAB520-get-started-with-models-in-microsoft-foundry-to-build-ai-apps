# Microsoft Foundry Project Configuration
# Copy this file to .env and fill in your values from Lab 2

# Your Foundry project endpoint (from azd env get-values or Foundry portal)
PROJECT_ENDPOINT=https://<your-resource>.services.ai.azure.com/api/projects/<your-project>

# Model deployment name (e.g., gpt-5.4-mini, gpt-5.4, Phi-4)
MODEL_DEPLOYMENT_NAME=gpt-5.4-mini

# (Optional) Second model for comparison in Lab 5
MODEL_DEPLOYMENT_NAME_2=gpt-5.4

# (Optional) Azure Container Registry name for Lab 6 agent deployment
AZURE_CONTAINER_REGISTRY_NAME=
